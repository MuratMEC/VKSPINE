generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id       String    @id @default(uuid())
  name     String
  isActive Boolean   @default(true)
  products Product[]
}

model Product {
  id             String          @id @default(uuid())
  barcode        String?         @unique
  utsCode        String?
  sku            String?
  name           String
  brand          String?
  productType    String?
  dimension      String?
  sutCode        String?
  taxRate        Float?          @default(20)
  purchasePrice  Float?
  salesPrice     Float?
  currency       String?         @default("TRY")
  minStockLvl    Float?          @default(5)
  isSterile      Boolean?        @default(false)
  hasExpiration  Boolean?        @default(true)
  categoryId     String?
  setCategoryId  String?
  isActive       Boolean         @default(true)
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lotSerials     LotSerial[]
  category       Category?       @relation(fields: [categoryId], references: [id])
  setCategory    SetCategory?    @relation(fields: [setCategoryId], references: [id])
  stockMovements StockMovement[]
}

model SetCategory {
  id       String    @id @default(uuid())
  name     String
  isActive Boolean   @default(true)
  products Product[]
}

model Supplier {
  id          String      @id @default(uuid())
  companyName   String
  taxOffice     String?
  taxNumber     String?     @map("taxNo")
  contactPerson String?     @map("contactName")
  phone         String?
  email         String?
  address       String?
  notes         String?
  isActive      Boolean     @default(true)
  lotSerials    LotSerial[]
}

model Customer {
  id          String    @id @default(uuid())
  name          String
  taxOffice     String?
  taxNumber     String?     @map("taxNo")
  contactPerson String?     @map("contactName")
  phone         String?
  email         String?
  address       String?
  notes         String?
  isActive      Boolean     @default(true)
  surgeries     Surgery[]
}

model LotSerial {
  id              String          @id @default(uuid())
  productId       String
  lotNo           String
  serialNo        String?
  expDate         DateTime        @map("expirationDate")
  productionDate  DateTime?
  supplierId      String?
  invoiceNo       String?
  entryDate       DateTime        @default(now())
  initialQuantity Float
  quantity        Float           @map("currentQuantity")
  shelfLocation   String?
  status          String          @default("active")
  createdAt       DateTime        @default(now())
  supplier        Supplier?       @relation(fields: [supplierId], references: [id])
  product         Product         @relation(fields: [productId], references: [id])
  StockMovement   StockMovement[]
  surgeryLines    SurgeryLine[]
}

model StockMovement {
  id          String    @id @default(uuid())
  lotSerialId String
  productId   String
  type        String    @map("movementType")
  quantity    Float
  previousQty Float?
  newQty      Float?
  referenceNo String?
  description String?
  createdAt   DateTime  @default(now()) @map("movementDate")
  product     Product   @relation(fields: [productId], references: [id])
  lotSerial   LotSerial @relation(fields: [lotSerialId], references: [id])
}

model Surgery {
  id           String        @id @default(uuid())
  customerId   String?
  doctorName   String?
  patientName  String?
  surgeryDate  DateTime      @default(now())
  status       String        @default("completed")
  notes        String?
  customer     Customer?     @relation(fields: [customerId], references: [id])
  surgeryLines SurgeryLine[]
}

model SurgeryLine {
  id          String    @id @default(uuid())
  surgeryId   String
  lotSerialId String
  quantity    Float
  lotSerial   LotSerial @relation(fields: [lotSerialId], references: [id])
  surgery     Surgery   @relation(fields: [surgeryId], references: [id])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
